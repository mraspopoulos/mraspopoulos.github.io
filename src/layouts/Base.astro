---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  active?: 'about' | 'research' | 'publications' | 'teaching' | 'cv';
}

const {
  title,
  description = 'Marios Raspopoulos — Associate Professor at UCLan Cyprus. Wireless communication, indoor positioning, IoT, and 6G.',
  active = 'about',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="author" content="Marios Raspopoulos" />
    <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site).href} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={new URL(Astro.url.pathname, Astro.site).href} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" type="application/rss+xml" href="/rss.xml" title="Marios Raspopoulos" />

    <title>{title}</title>

    <script is:inline>
      // Read saved theme before paint to prevent flash
      const saved = localStorage.getItem('theme');
      if (saved) document.documentElement.setAttribute('data-theme', saved);
    </script>
  </head>
  <body>
    <header class="site-header">
      <Nav active={active} />
    </header>
    <div class="page-wrap">
      <main>
        <slot />
      </main>
    </div>
    <Footer />

    <script>
      const btn = document.querySelector('.theme-toggle');
      const sunPath = btn?.querySelector('.sun');
      const moonPath = btn?.querySelector('.moon');

      const apply = (mode: 'light' | 'dark') => {
        document.documentElement.setAttribute('data-theme', mode);
        localStorage.setItem('theme', mode);
        if (sunPath && moonPath) {
          (sunPath as HTMLElement).style.display = mode === 'dark' ? 'inline' : 'none';
          (moonPath as HTMLElement).style.display = mode === 'dark' ? 'none' : 'inline';
        }
      };

      // Initialize toggle icon to match current state
      const current = document.documentElement.getAttribute('data-theme')
        ?? (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
      if (sunPath && moonPath) {
        (sunPath as HTMLElement).style.display = current === 'dark' ? 'inline' : 'none';
        (moonPath as HTMLElement).style.display = current === 'dark' ? 'none' : 'inline';
      }

      btn?.addEventListener('click', () => {
        const now = document.documentElement.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
        apply(now);
      });

      // Expandable description toggles
      document.querySelectorAll('[data-expandable]').forEach((wrap) => {
        const content = wrap.querySelector('.expandable-content') as HTMLElement | null;
        const toggle = wrap.querySelector('.expandable-toggle') as HTMLButtonElement | null;
        const label = wrap.querySelector('.expandable-toggle-text') as HTMLElement | null;
        if (!content || !toggle || !label) return;
        // Hide toggle if content fits in collapsed height (no overflow)
        if (content.scrollHeight <= content.clientHeight + 4) {
          wrap.classList.add('short');
          return;
        }
        toggle.addEventListener('click', () => {
          const expanded = wrap.classList.toggle('expanded');
          label.textContent = expanded ? 'Show less' : 'Read more';
        });
      });
    </script>
  </body>
</html>
