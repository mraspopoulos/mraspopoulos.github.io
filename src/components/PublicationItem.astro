---
import type { CollectionEntry } from 'astro:content';
import citationsData from '../data/citations.json';

interface Props {
  pub: CollectionEntry<'publications'>;
}
const { pub } = Astro.props;
const d = pub.data;

const counts = (citationsData as any).counts ?? {};
const doi = (d.doi || '').toLowerCase().trim();
const citationCount: number | null = doi && doi in counts ? counts[doi] : null;

const typeLabels: Record<string, string> = {
  journal: 'journal',
  conference: 'conf.',
  book: 'book',
  chapter: 'chapter',
  preprint: 'preprint',
};

const typeIcons: Record<string, string> = {
  // Journal — small page with line
  journal: '<rect x="4" y="3" width="16" height="18" rx="1"/><line x1="8" y1="8" x2="16" y2="8"/><line x1="8" y1="12" x2="16" y2="12"/><line x1="8" y1="16" x2="13" y2="16"/>',
  // Conference — people / microphone
  conference: '<rect x="5" y="9" width="14" height="11" rx="2"/><circle cx="12" cy="14" r="2"/><line x1="9" y1="5" x2="15" y2="5"/><line x1="12" y1="3" x2="12" y2="9"/>',
  // Book — closed book
  book: '<path d="M4 4v16a2 2 0 0 0 2 2h14V2H6a2 2 0 0 0-2 2z"/><line x1="8" y1="6" x2="16" y2="6"/>',
  chapter: '<path d="M4 4v16a2 2 0 0 0 2 2h14V2H6a2 2 0 0 0-2 2z"/><line x1="8" y1="6" x2="16" y2="6"/><line x1="8" y1="10" x2="14" y2="10"/>',
  // Preprint — page with arrow up
  preprint: '<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><polyline points="9 15 12 12 15 15"/>',
};

const t = d.type;
const label = typeLabels[t] ?? t;
const icon = typeIcons[t] ?? typeIcons.journal;
---

<li class="pub-item">
  <div class="pub-year">
    <span>{d.year}</span>
    <span class={`pub-type ${t}`} title={`${label} publication`}>
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" set:html={icon} />
      {label}
    </span>
  </div>
  <div class="pub-body">
    <p class="pub-title">{d.title}</p>
    <p class="pub-venue">{d.authors} · <em>{d.venue}</em></p>
    <div class="pub-links">
      {d.pdf && (
        <a href={d.pdf}>
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
          PDF
        </a>
      )}
      {d.doi && (
        <a href={`https://doi.org/${d.doi}`}>
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
          DOI
        </a>
      )}
      {d.url && !d.doi && (
        <a href={d.url}>
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
          Link
        </a>
      )}
      {d.scholar && (
        <a href={d.scholar}>
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/></svg>
          Scholar
        </a>
      )}
      {citationCount !== null && citationCount > 0 && (
        <a href={`https://openalex.org/works?filter=doi:${doi}`} class="pub-citations" title="Citation count from OpenAlex">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21c0-4 3-7 7-7h.5"/><path d="M14 21c0-4 3-7 7-7"/><path d="M3 3h7v7h-7z"/><path d="M14 3h7v7h-7z"/></svg>
          Cited by {citationCount}
        </a>
      )}
      {d.bibtex && (
        <a href={d.bibtex}>
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21v-13a2 2 0 0 1 2-2h3l2-3h6l2 3h3a2 2 0 0 1 2 2v13z"/><path d="M9 14l2 2 4-4"/></svg>
          BibTeX
        </a>
      )}
    </div>
  </div>
</li>
