---
import type { CollectionEntry } from 'astro:content';
import { render } from 'astro:content';

interface Props {
  project: CollectionEntry<'projects'>;
}
const { project } = Astro.props;
const d = project.data;

const fmtMonth = (date: Date) =>
  date.toLocaleDateString('en-GB', { month: 'short', year: 'numeric' });

const { Content } = await render(project);
const hasLogo = Boolean(d.logo);
const partners = d.partners || [];
const partnersShort = partners.slice(0, 2);
const partnersRest = partners.length > 3 ? partners.slice(2) : [];
const showPartnersToggle = partnersRest.length > 0;
---

<article class="project-card">
  <div class={`project-logo ${hasLogo ? '' : 'is-placeholder'}`}>
    {hasLogo ? (
      <img src={d.logo} alt={`${d.title} logo`} loading="lazy" />
    ) : (
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
        <polyline points="14 2 14 8 20 8"/>
        <line x1="9" y1="13" x2="15" y2="13"/>
        <line x1="9" y1="17" x2="15" y2="17"/>
      </svg>
    )}
  </div>
  <div class="project-body">
    <header class="project-head">
      <h3 class="project-title">{d.title}</h3>
      <span class="badge">{d.role}</span>
    </header>
    <div class="expandable" data-expandable>
      <div class="expandable-content">
        <Content />
      </div>
      <button type="button" class="expandable-toggle" aria-label="Toggle description">
        <span class="expandable-toggle-text">Read more</span>
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
      </button>
    </div>
    {d.roleDetail && (
      <details class="meta-collapsible">
        <summary><span class="meta-label">Role detail</span></summary>
        <p>{d.roleDetail}</p>
      </details>
    )}
    {partners.length > 0 && (
      <div class="meta-collapsible-static">
        <span class="meta-label">Partners</span>
        <span class="partners-list">
          <span class="partners-visible">{partnersShort.join(' · ')}</span>
          {showPartnersToggle && (
            <details class="partners-more">
              <summary>+{partnersRest.length} more</summary>
              <span> · {partnersRest.join(' · ')}</span>
            </details>
          )}
          {!showPartnersToggle && partners.length > 2 && (
            <span> · {partners.slice(2).join(' · ')}</span>
          )}
        </span>
      </div>
    )}
    <div class="project-meta">
      <span>
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
        {fmtMonth(d.startDate)} – {fmtMonth(d.endDate)}
      </span>
      {d.budget && (
        <span>
<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 7a6 6 0 0 0-4.5-2C9.9 5 7 8.1 7 12s2.9 7 6.5 7a6 6 0 0 0 4.5-2"/><line x1="4" y1="10" x2="14" y2="10"/><line x1="4" y1="14" x2="14" y2="14"/></svg>          {d.budget}
        </span>
      )}
      {d.funder && (
        <span>
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="21" x2="21" y2="21"/><line x1="3" y1="10" x2="21" y2="10"/><polyline points="5,6 12,3 19,6"/><line x1="4" y1="10" x2="4" y2="21"/><line x1="20" y1="10" x2="20" y2="21"/><line x1="8" y1="14" x2="8" y2="17"/><line x1="12" y1="14" x2="12" y2="17"/><line x1="16" y1="14" x2="16" y2="17"/></svg>
          {d.funder}
        </span>
      )}
      {d.funderRef && (
        <span><code>{d.funderRef}</code></span>
      )}
      {d.url && (
        <span><a href={d.url}>Project site &rarr;</a></span>
      )}
    </div>
  </div>
</article>
