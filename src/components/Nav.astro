---
interface Props {
  active?: 'about' | 'research' | 'publications' | 'teaching' | 'cv';
}
const { active = 'about' } = Astro.props;

const items = [
  { href: '/', label: 'About', key: 'about' },
  { href: '/research/', label: 'Research', key: 'research' },
  { href: '/publications/', label: 'Publications', key: 'publications' },
  { href: '/teaching/', label: 'Teaching', key: 'teaching' },
  { href: '/cv/', label: 'CV', key: 'cv' },
];
---

<nav class="nav">
  <a href="/" class="nav-brand">Marios Raspopoulos</a>
  <div style="display: flex; align-items: center; gap: 1rem;">
    <div class="nav-links">
      {items.map((item) => (
        <a href={item.href} class={active === item.key ? 'active' : ''}>{item.label}</a>
      ))}
    </div>
    <button class="theme-toggle" aria-label="Toggle theme">
      <svg class="sun" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="display:none">
        <circle cx="12" cy="12" r="4"/>
        <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"/>
      </svg>
      <svg class="moon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
      </svg>
    </button>
  </div>
</nav>
