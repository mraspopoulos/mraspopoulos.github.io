---
// All hero content is editable here in one place.
const links = [
  { href: 'mailto:mraspopoulos@uclan.ac.uk', label: 'Email', icon: 'mail' },
  { href: 'https://scholar.google.com/citations?user=5UUd8nYAAAAJ', label: 'Scholar', icon: 'scholar' },
  { href: 'https://orcid.org/0000-0003-1513-6018', label: 'ORCID', icon: 'orcid' },
  { href: 'https://github.com/mraspopoulos', label: 'GitHub', icon: 'github' },
  { href: 'https://www.linkedin.com/in/marios-raspopoulos-72514a7', label: 'LinkedIn', icon: 'linkedin' },
  { href: 'https://www.researchgate.net/profile/Marios-Raspopoulos', label: 'ResearchGate', icon: 'researchgate' },
];

const icons: Record<string, string> = {
  mail: '<path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/>',
  scholar: '<path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/>',
  orcid: '<circle cx="12" cy="12" r="10"/><text x="12" y="16" text-anchor="middle" font-size="10" font-family="sans-serif" font-weight="700" stroke="none" fill="currentColor">iD</text>',
  github: '<path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/>',
  linkedin: '<path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-4 0v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/>',
  researchgate: '<circle cx="12" cy="12" r="10"/><path d="M12 7v10M9 10c0-1.5 1-3 3-3s3 1.5 3 3-1 3-3 3h-3l5 4"/>',
};
---

<section class="hero">
  <img class="hero-photo" src="/images/photo.jpg" alt="Marios Raspopoulos" />
  <div class="hero-content">
    <h1 class="hero-name">Marios Raspopoulos</h1>
    <div class="hero-rule"></div>
    <p class="hero-role">Associate Professor · Deputy Head of School</p>
    <p class="hero-affiliation">School of Sciences, UCLan Cyprus · <a href="http://inspirecenter.org/">INSPIRE Centre</a> member</p>
    <p class="hero-bio">
      Wireless communication, radio-wave propagation, indoor positioning, and the Internet of Things.
      Current focus: 3D positioning in RIS-aided 6G environments, mmWave sensing, and machine-learning-assisted beam management.
    </p>
    <div class="hero-links">
      {links.map((link) => (
        <a href={link.href}>
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" set:html={icons[link.icon]} />
          {link.label}
        </a>
      ))}
    </div>
  </div>
</section>
