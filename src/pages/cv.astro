    period: 'Sep 2004 – Aug 2007',
    url: 'https://www.surrey.ac.uk/',
    logo: '/images/affiliations/surrey_logo.png',
    roles: [
      { title: 'Research Assistant / Associate', period: '', notes: ['Centre for Communications Systems Research', 'Participation in research and development projects', 'Teaching Assistant'] },
    ],
  },
